{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/source-bundle-v1.json",
  "title": "Encounter Source Bundle",
  "type": "object",
  "additionalProperties": false,
  "required": ["case_id", "patient_id", "encounter_id", "admitted_at", "discharged_at", "documents", "claim"],
  "properties": {
    "case_id": {"type": "string", "minLength": 1},
    "patient_id": {"type": "string", "minLength": 1},
    "encounter_id": {"type": "string", "minLength": 1},
    "admitted_at": {"type": "string", "format": "date-time"},
    "discharged_at": {"type": "string", "format": "date-time"},
    "metadata": {"type": "object"},
    "documents": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["document_id", "author_role", "recorded_at", "text"],
        "properties": {
          "document_id": {"type": "string", "minLength": 1},
          "author_role": {"type": "string", "minLength": 1},
          "recorded_at": {"type": "string", "format": "date-time"},
          "text": {"type": "string", "minLength": 1}
        }
      }
    },
    "claim": {"$ref": "https://example.org/schemas/claim-v1.json"},
    "structured_extraction": {"$ref": "https://example.org/schemas/extraction-fragment-v1.json"},
    "ingestion_provenance": {"$ref": "#/$defs/ingestionProvenance"}
  },
  "$defs": {
    "ingestionProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["framework", "adapter_id", "adapter_version", "source_schema_fingerprint", "input_manifest_digest", "transformed_at", "runtime_version"],
      "properties": {
        "framework": {"const": "deterministic-adapter"},
        "adapter_id": {"type": "string", "minLength": 1},
        "adapter_version": {"type": "string", "minLength": 1},
        "source_schema_fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "input_manifest_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "transformed_at": {"type": "string", "format": "date-time"},
        "runtime_version": {"type": "string", "minLength": 1}
      }
    }
  }
}
