{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/review-decision-v2.json",
  "title": "Governed Review Decision",
  "type": "object",
  "additionalProperties": false,
  "required": ["decision_schema_version", "decision_id", "tenant_id", "workspace_id", "packet_id", "finding_id", "action", "reason_code", "reason", "actor_id", "actor_roles", "decided_at", "packet_record_hash", "packet_hash", "automation_plan_hash", "automation_policy_hash", "idempotency_key", "previous_decision_hash", "decision_hash"],
  "properties": {
    "decision_schema_version": {"const": "2.0.0"},
    "decision_id": {"type": "string", "pattern": "^decision-[0-9a-f]{20}$"},
    "tenant_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "workspace_id": {"type": "string", "minLength": 1, "maxLength": 128},
    "packet_id": {"type": "string", "pattern": "^packet-[0-9a-f]{20}$"},
    "finding_id": {"type": "string", "minLength": 1},
    "action": {"enum": ["route_to_coding", "route_to_cdi", "route_to_charge_review", "route_to_compliance", "dismiss_with_reason"]},
    "reason_code": {"enum": ["evidence_confirmed", "documentation_not_supported", "duplicate", "already_corrected", "other_governed"]},
    "reason": {"type": "string", "minLength": 1, "maxLength": 1000},
    "actor_id": {"type": "string", "minLength": 1},
    "actor_roles": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"enum": ["coder", "cdi_specialist", "charge_reviewer", "compliance_reviewer", "admin", "read_only"]}},
    "decided_at": {"type": "string", "format": "date-time"},
    "packet_record_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "packet_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "automation_plan_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "automation_policy_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "idempotency_key": {"type": "string", "minLength": 1, "maxLength": 128},
    "previous_decision_hash": {"type": ["string", "null"], "pattern": "^[0-9a-f]{64}$"},
    "decision_hash": {"type": "string", "pattern": "^[0-9a-f]{64}$"}
  },
  "allOf": [
    {
      "if": {"properties": {"action": {"const": "dismiss_with_reason"}}, "required": ["action"]},
      "then": {"properties": {"reason_code": {"enum": ["documentation_not_supported", "duplicate", "already_corrected", "other_governed"]}}},
      "else": {"properties": {"reason_code": {"const": "evidence_confirmed"}}}
    }
  ]
}
