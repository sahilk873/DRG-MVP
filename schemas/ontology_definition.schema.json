{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/ontology-definition-v1.json",
  "title": "Extensible Encounter Ontology Definition",
  "type": "object",
  "required": ["ontology_id", "version", "status", "structural_graph", "classes", "relations"],
  "properties": {
    "ontology_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "status": {"enum": ["draft", "clinical-review-required", "approved"]},
    "purpose": {"type": "string", "minLength": 1},
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id", "title", "contribution"],
        "properties": {
          "source_id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "contribution": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "structural_graph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entities", "relations"],
      "properties": {
        "entities": {"type": "array", "items": {"$ref": "#/$defs/ontologyEntity"}},
        "relations": {"type": "array", "items": {"$ref": "#/$defs/ontologyRelation"}}
      }
    },
    "classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["class_id", "label"],
        "properties": {
          "class_id": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "parent": {"type": "string", "minLength": 1},
          "abstract": {"type": "boolean"},
          "value_set": {"type": "string", "minLength": 1}
        },
        "additionalProperties": false
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["relation_id", "domain", "range", "requires_evidence"],
        "properties": {
          "relation_id": {"type": "string", "minLength": 1},
          "domain": {"$ref": "#/$defs/nonEmptyStringArray"},
          "range": {"$ref": "#/$defs/nonEmptyStringArray"},
          "requires_evidence": {"type": "boolean"}
        },
        "additionalProperties": false
      }
    },
    "value_sets": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/nonEmptyStringArray"}
    }
  },
  "additionalProperties": false,
  "$defs": {
    "nonEmptyString": {"type": "string", "minLength": 1},
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    },
    "conceptCode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "code", "display"],
      "properties": {
        "system": {"$ref": "#/$defs/nonEmptyString"},
        "code": {"$ref": "#/$defs/nonEmptyString"},
        "display": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "ontologyEntity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_id", "entity_type", "label", "properties"],
      "properties": {
        "entity_id": {"$ref": "#/$defs/nonEmptyString"},
        "entity_type": {"$ref": "#/$defs/nonEmptyString"},
        "label": {"$ref": "#/$defs/nonEmptyString"},
        "concept": {"$ref": "#/$defs/conceptCode"},
        "properties": {"type": "object"}
      }
    },
    "ontologyRelation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relation_id", "predicate", "source_id", "target_id", "assertion_status", "documentation_status", "confidence", "evidence_ids"],
      "properties": {
        "relation_id": {"$ref": "#/$defs/nonEmptyString"},
        "predicate": {"$ref": "#/$defs/nonEmptyString"},
        "source_id": {"$ref": "#/$defs/nonEmptyString"},
        "target_id": {"$ref": "#/$defs/nonEmptyString"},
        "assertion_status": {"enum": ["present", "absent", "uncertain", "historical"]},
        "documentation_status": {"enum": ["explicit", "inferred", "conflicted", "absent"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "evidence_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonEmptyString"}},
        "contradicting_evidence_ids": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonEmptyString"}}
      }
    }
  }
}
