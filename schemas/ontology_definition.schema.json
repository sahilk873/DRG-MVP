{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/ontology-definition-v1.json",
  "title": "Extensible Encounter Ontology Definition",
  "type": "object",
  "required": ["ontology_id", "version", "status", "classes", "relations"],
  "properties": {
    "ontology_id": {"type": "string", "minLength": 1},
    "version": {"type": "string", "minLength": 1},
    "status": {"enum": ["draft", "clinical-review-required", "approved"]},
    "purpose": {"type": "string", "minLength": 1},
    "sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id", "title", "contribution"],
        "properties": {
          "source_id": {"type": "string", "minLength": 1},
          "title": {"type": "string", "minLength": 1},
          "contribution": {"type": "string", "minLength": 1}
        },
        "additionalProperties": true
      }
    },
    "classes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["class_id", "label"],
        "properties": {
          "class_id": {"type": "string", "minLength": 1},
          "label": {"type": "string", "minLength": 1},
          "parent": {"type": "string", "minLength": 1},
          "abstract": {"type": "boolean"},
          "value_set": {"type": "string", "minLength": 1}
        },
        "additionalProperties": true
      }
    },
    "relations": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["relation_id", "domain", "range", "requires_evidence"],
        "properties": {
          "relation_id": {"type": "string", "minLength": 1},
          "domain": {"$ref": "#/$defs/nonEmptyStringArray"},
          "range": {"$ref": "#/$defs/nonEmptyStringArray"},
          "requires_evidence": {"type": "boolean"}
        },
        "additionalProperties": true
      }
    },
    "value_sets": {
      "type": "object",
      "additionalProperties": {"$ref": "#/$defs/nonEmptyStringArray"}
    }
  },
  "additionalProperties": true,
  "$defs": {
    "nonEmptyStringArray": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"type": "string", "minLength": 1}
    }
  }
}
