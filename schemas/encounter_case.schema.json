{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/encounter-case-v2.json",
  "title": "Encounter Case Evidence Graph",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "case_id", "patient_id", "encounter_id", "admitted_at", "discharged_at", "evidence", "ontology", "assertions", "claim", "provenance"],
  "properties": {
    "schema_version": {"const": "2.0.0"},
    "case_id": {"$ref": "#/$defs/nonEmptyString"},
    "patient_id": {"$ref": "#/$defs/nonEmptyString"},
    "encounter_id": {"$ref": "#/$defs/nonEmptyString"},
    "admitted_at": {"type": "string", "format": "date-time"},
    "discharged_at": {"type": "string", "format": "date-time"},
    "metadata": {"type": "object"},
    "evidence": {"type": "array", "items": {"$ref": "#/$defs/evidence"}},
    "ontology": {"$ref": "#/$defs/ontologyGraph"},
    "assertions": {"type": "array", "items": {"$ref": "#/$defs/assertion"}},
    "claim": {"$ref": "https://example.org/schemas/claim-v1.json"},
    "provenance": {"$ref": "#/$defs/provenance"},
    "documents": {"type": "array", "items": {"$ref": "#/$defs/document"}},
    "assessments": {"type": "array", "items": {"$ref": "#/$defs/woundAssessment"}},
    "episode": {"$ref": "#/$defs/episode"}
  },
  "$defs": {
    "nonEmptyString": {"type": "string", "minLength": 1},
    "document": {
      "type": "object",
      "additionalProperties": false,
      "required": ["document_id", "text"],
      "properties": {
        "document_id": {"$ref": "#/$defs/nonEmptyString"},
        "text": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "sizeMeasurement": {
      "type": "object",
      "additionalProperties": false,
      "required": ["length_cm", "width_cm"],
      "properties": {
        "length_cm": {"type": "number", "minimum": 0},
        "width_cm": {"type": "number", "minimum": 0},
        "depth_cm": {"type": "number", "minimum": 0}
      }
    },
    "woundAssessment": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assessment_id", "observed_at", "evidence_ids"],
      "properties": {
        "assessment_id": {"$ref": "#/$defs/nonEmptyString"},
        "observed_at": {"type": "string", "format": "date-time"},
        "size": {"$ref": "#/$defs/sizeMeasurement"},
        "tissue": {"$ref": "#/$defs/nonEmptyString"},
        "exudate": {"$ref": "#/$defs/nonEmptyString"},
        "periwound": {"$ref": "#/$defs/nonEmptyString"},
        "standard_care_documented": {"type": "boolean"},
        "provider_reassessment": {"type": "boolean"},
        "compared_with_id": {"$ref": "#/$defs/nonEmptyString"},
        "subject_entity_id": {"$ref": "#/$defs/nonEmptyString"},
        "attributes": {"type": "object"},
        "evidence_ids": {"allOf": [{"$ref": "#/$defs/uniqueStringArray"}, {"type": "array", "minItems": 1}]}
      }
    },
    "episode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["episode_id", "patient_id", "episode_start"],
      "properties": {
        "episode_id": {"$ref": "#/$defs/nonEmptyString"},
        "patient_id": {"$ref": "#/$defs/nonEmptyString"},
        "episode_start": {"type": "string", "format": "date-time"},
        "episode_end": {"type": "string", "format": "date-time"},
        "encounter_ids": {"$ref": "#/$defs/uniqueStringArray"}
      }
    },
    "uniqueStringArray": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonEmptyString"}},
    "evidence": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evidence_id", "document_id", "author_role", "recorded_at", "text"],
      "properties": {
        "evidence_id": {"$ref": "#/$defs/nonEmptyString"},
        "document_id": {"$ref": "#/$defs/nonEmptyString"},
        "author_role": {"$ref": "#/$defs/nonEmptyString"},
        "recorded_at": {"type": "string", "format": "date-time"},
        "text": {"$ref": "#/$defs/nonEmptyString"},
        "source_locator": {"$ref": "#/$defs/sourceLocator"}
      }
    },
    "sourceLocator": {
      "type": "object",
      "additionalProperties": false,
      "required": ["adapter_id", "adapter_version", "resource", "path", "row_number", "source_record_id", "field_names"],
      "properties": {
        "adapter_id": {"$ref": "#/$defs/nonEmptyString"},
        "adapter_version": {"$ref": "#/$defs/nonEmptyString"},
        "resource": {"$ref": "#/$defs/nonEmptyString"},
        "path": {"$ref": "#/$defs/nonEmptyString"},
        "sheet": {"$ref": "#/$defs/nonEmptyString"},
        "row_number": {"type": "integer", "minimum": 1},
        "source_record_id": {"$ref": "#/$defs/nonEmptyString"},
        "field_names": {"allOf": [{"$ref": "#/$defs/uniqueStringArray"}, {"type": "array", "minItems": 1}]}
      }
    },
    "conceptCode": {
      "type": "object",
      "additionalProperties": false,
      "required": ["system", "code", "display"],
      "properties": {
        "system": {"$ref": "#/$defs/nonEmptyString"},
        "code": {"$ref": "#/$defs/nonEmptyString"},
        "display": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "ontologyEntity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["entity_id", "entity_type", "label", "properties"],
      "properties": {
        "entity_id": {"$ref": "#/$defs/nonEmptyString"},
        "entity_type": {"$ref": "#/$defs/nonEmptyString"},
        "label": {"$ref": "#/$defs/nonEmptyString"},
        "concept": {"$ref": "#/$defs/conceptCode"},
        "properties": {"type": "object"}
      }
    },
    "ontologyRelation": {
      "type": "object",
      "additionalProperties": false,
      "required": ["relation_id", "predicate", "source_id", "target_id", "assertion_status", "documentation_status", "confidence", "evidence_ids"],
      "properties": {
        "relation_id": {"$ref": "#/$defs/nonEmptyString"},
        "predicate": {"$ref": "#/$defs/nonEmptyString"},
        "source_id": {"$ref": "#/$defs/nonEmptyString"},
        "target_id": {"$ref": "#/$defs/nonEmptyString"},
        "assertion_status": {"enum": ["present", "absent", "uncertain", "historical"]},
        "documentation_status": {"enum": ["explicit", "inferred", "conflicted", "absent"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "evidence_ids": {"$ref": "#/$defs/uniqueStringArray"},
        "contradicting_evidence_ids": {"$ref": "#/$defs/uniqueStringArray"}
      }
    },
    "ontologyGraph": {
      "type": "object",
      "additionalProperties": false,
      "required": ["ontology_id", "ontology_version", "ontology_digest", "entities", "relations"],
      "properties": {
        "ontology_id": {"$ref": "#/$defs/nonEmptyString"},
        "ontology_version": {"$ref": "#/$defs/nonEmptyString"},
        "ontology_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "entities": {"type": "array", "items": {"$ref": "#/$defs/ontologyEntity"}},
        "relations": {"type": "array", "items": {"$ref": "#/$defs/ontologyRelation"}}
      }
    },
    "assertion": {
      "type": "object",
      "additionalProperties": false,
      "required": ["assertion_id", "subject_id", "concept", "status", "documentation_status", "confidence", "attributes", "evidence_ids"],
      "properties": {
        "assertion_id": {"$ref": "#/$defs/nonEmptyString"},
        "subject_id": {"$ref": "#/$defs/nonEmptyString"},
        "concept": {"$ref": "#/$defs/nonEmptyString"},
        "status": {"enum": ["present", "absent", "uncertain", "historical"]},
        "documentation_status": {"enum": ["explicit", "inferred", "conflicted", "absent"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "attributes": {"type": "object"},
        "evidence_ids": {"allOf": [{"$ref": "#/$defs/uniqueStringArray"}, {"type": "array", "minItems": 1}]},
        "contradicting_evidence_ids": {"$ref": "#/$defs/uniqueStringArray"}
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["framework", "model_id", "agent_id", "extracted_at", "schema_version", "extraction_policy"],
      "properties": {
        "framework": {"const": "mastra"},
        "model_id": {"$ref": "#/$defs/nonEmptyString"},
        "agent_id": {"$ref": "#/$defs/nonEmptyString"},
        "extracted_at": {"type": "string", "format": "date-time"},
        "schema_version": {"const": "2.0.0"},
        "extraction_policy": {"$ref": "#/$defs/extractionPolicy"},
        "ingestion": {"$ref": "#/$defs/ingestionProvenance"}
      }
    },
    "ingestionProvenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["framework", "adapter_id", "adapter_version", "source_schema_fingerprint", "input_manifest_digest", "transformed_at", "runtime_version"],
      "properties": {
        "framework": {"const": "deterministic-adapter"},
        "adapter_id": {"$ref": "#/$defs/nonEmptyString"},
        "adapter_version": {"$ref": "#/$defs/nonEmptyString"},
        "source_schema_fingerprint": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "input_manifest_digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
        "transformed_at": {"type": "string", "format": "date-time"},
        "runtime_version": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "extractionPolicy": {
      "type": "object",
      "additionalProperties": false,
      "required": ["max_documents", "max_document_characters", "max_total_document_characters", "max_evidence_items", "max_evidence_characters", "max_total_evidence_characters", "max_entities", "max_relations", "max_assertions"],
      "properties": {
        "max_documents": {"type": "integer", "minimum": 1},
        "max_document_characters": {"type": "integer", "minimum": 1},
        "max_total_document_characters": {"type": "integer", "minimum": 1},
        "max_evidence_items": {"type": "integer", "minimum": 1},
        "max_evidence_characters": {"type": "integer", "minimum": 1},
        "max_total_evidence_characters": {"type": "integer", "minimum": 1},
        "max_entities": {"type": "integer", "minimum": 1},
        "max_relations": {"type": "integer", "minimum": 1},
        "max_assertions": {"type": "integer", "minimum": 1}
      }
    }
  }
}
