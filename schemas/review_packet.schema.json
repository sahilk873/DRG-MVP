{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.org/schemas/review-packet-v2.json",
  "title": "Revenue Integrity Human Review Packet",
  "type": "object",
  "additionalProperties": false,
  "required": ["review_packet_schema_version", "packet_id", "environment", "tenant", "case", "evidence", "ontology", "assertions", "findings", "controls", "provenance"],
  "properties": {
    "review_packet_schema_version": {"const": "2.0.0"},
    "packet_id": {"type": "string", "pattern": "^packet-[0-9a-f]{20}$"},
    "environment": {"enum": ["development", "synthetic", "validation", "production"]},
    "tenant": {"$ref": "#/$defs/tenant"},
    "case": {"$ref": "#/$defs/caseSummary"},
    "evidence": {"type": "array", "items": {"$ref": "https://example.org/schemas/encounter-case-v2.json#/$defs/evidence"}},
    "ontology": {"$ref": "https://example.org/schemas/encounter-case-v2.json#/$defs/ontologyGraph"},
    "assertions": {"type": "array", "items": {"$ref": "https://example.org/schemas/encounter-case-v2.json#/$defs/assertion"}},
    "findings": {"type": "array", "items": {"$ref": "#/$defs/finding"}},
    "controls": {"$ref": "#/$defs/controls"},
    "provenance": {"$ref": "#/$defs/provenance"}
  },
  "$defs": {
    "nonEmptyString": {"type": "string", "minLength": 1},
    "digest": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "uniqueStringArray": {"type": "array", "uniqueItems": true, "items": {"$ref": "#/$defs/nonEmptyString"}},
    "tenant": {
      "type": "object", "additionalProperties": false,
      "required": ["tenant_id", "workspace_id"],
      "properties": {
        "tenant_id": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._-]+$"},
        "workspace_id": {"type": "string", "minLength": 1, "maxLength": 128, "pattern": "^[A-Za-z0-9._-]+$"}
      }
    },
    "caseSummary": {
      "type": "object",
      "additionalProperties": false,
      "required": ["schema_version", "case_id", "patient_id", "encounter_id", "admitted_at", "discharged_at", "metadata", "claim"],
      "properties": {
        "schema_version": {"const": "2.0.0"},
        "case_id": {"$ref": "#/$defs/nonEmptyString"},
        "patient_id": {"$ref": "#/$defs/nonEmptyString"},
        "encounter_id": {"$ref": "#/$defs/nonEmptyString"},
        "admitted_at": {"type": "string", "format": "date-time"},
        "discharged_at": {"type": "string", "format": "date-time"},
        "metadata": {"type": "object"},
        "claim": {"$ref": "https://example.org/schemas/claim-v1.json"}
      }
    },
    "finding": {
      "type": "object",
      "additionalProperties": false,
      "required": ["finding_id", "rule_id", "rule_package_id", "rule_package_version", "title", "disposition", "confidence", "proposed_change", "subject_ids", "assertion_ids", "evidence_ids", "contradicting_evidence_ids", "rationale", "requires_human_review", "submitted_drg", "current_drg", "simulated_drg", "estimated_impact_cents", "grouper_version"],
      "properties": {
        "finding_id": {"$ref": "#/$defs/nonEmptyString"},
        "rule_id": {"$ref": "#/$defs/nonEmptyString"},
        "rule_package_id": {"$ref": "#/$defs/nonEmptyString"},
        "rule_package_version": {"$ref": "#/$defs/nonEmptyString"},
        "title": {"$ref": "#/$defs/nonEmptyString"},
        "disposition": {"enum": ["coding_review", "cdi_query", "charge_review", "compliance_review", "insufficient_evidence", "no_opportunity"]},
        "confidence": {"type": "number", "minimum": 0, "maximum": 1},
        "proposed_change": {"type": "object"},
        "subject_ids": {"$ref": "#/$defs/uniqueStringArray"},
        "assertion_ids": {"$ref": "#/$defs/uniqueStringArray"},
        "evidence_ids": {"$ref": "#/$defs/uniqueStringArray"},
        "contradicting_evidence_ids": {"$ref": "#/$defs/uniqueStringArray"},
        "rationale": {"$ref": "#/$defs/nonEmptyString"},
        "requires_human_review": {"type": "boolean"},
        "submitted_drg": {"type": ["string", "null"], "minLength": 1},
        "current_drg": {"$ref": "#/$defs/nonEmptyString"},
        "simulated_drg": {"$ref": "#/$defs/nonEmptyString"},
        "estimated_impact_cents": {"type": "integer"},
        "grouper_version": {"$ref": "#/$defs/nonEmptyString"}
      }
    },
    "controls": {
      "type": "object",
      "additionalProperties": false,
      "required": ["claim_mutation_allowed", "human_review_required", "permitted_actions"],
      "properties": {
        "claim_mutation_allowed": {"const": false},
        "human_review_required": {"type": "boolean"},
        "permitted_actions": {
          "type": "array",
          "uniqueItems": true,
          "items": {"enum": ["route_to_coding", "route_to_cdi", "route_to_charge_review", "route_to_compliance", "dismiss_with_reason"]}
        }
      }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "required": ["evaluated_at", "engine_version", "case_hash", "rule_package_id", "rule_package_version", "rule_package_hash", "record_hash", "previous_record_hash", "grouper_versions"],
      "properties": {
        "evaluated_at": {"type": "string", "format": "date-time"},
        "engine_version": {"$ref": "#/$defs/nonEmptyString"},
        "case_hash": {"$ref": "#/$defs/digest"},
        "rule_package_id": {"$ref": "#/$defs/nonEmptyString"},
        "rule_package_version": {"$ref": "#/$defs/nonEmptyString"},
        "rule_package_hash": {"$ref": "#/$defs/digest"},
        "record_hash": {"$ref": "#/$defs/digest"},
        "previous_record_hash": {"anyOf": [{"$ref": "#/$defs/nonEmptyString"}, {"type": "null"}]},
        "grouper_versions": {"$ref": "#/$defs/uniqueStringArray"}
      }
    }
  }
}
