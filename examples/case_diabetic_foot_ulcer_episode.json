  "documents": [
    {
      "document_id": "DFU-EVAL-DAY0",
      "text": "Initial diabetic foot ulcer evaluation. Right plantar forefoot ulcer measures 2.4 x 1.8 cm with a granulating wound bed. Periwound intact. Protective sensation is reduced on monofilament testing and the wound probes to bone. Standard care initiated."
    },
    {
      "document_id": "DFU-VISIT-DAY7",
      "text": "Day 7 wound care follow-up. Offloading boot provided and moist wound dressing applied. Ulcer stable at 2.4 x 1.8 cm. Continue standard care."
    },
    {
      "document_id": "DFU-VISIT-DAY14",
      "text": "Day 14 reassessment. Ulcer remains 2.4 x 1.8 cm with no size reduction despite two weeks of standard care. No provider reassessment noted for advanced therapy."
    },
    {
      "document_id": "DFU-VISIT-DAY28",
      "text": "Day 28 emergency department visit. Ulcer worsened to 3.1 x 2.6 cm. Purulent drainage, warm periwound, and cellulitis. IV antibiotics started."
    }
  ],
